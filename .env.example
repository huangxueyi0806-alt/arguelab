# ArgueLab — Configuration Template
# Copy this file to .env and fill in your credentials.
# ⚠️  .env is gitignored — never commit real credentials.
#
# ── Supabase (subscriber management) ──
# Get these from your Supabase project dashboard → Settings → API.
# SUPABASE_URL is the Project URL.
# SUPABASE_SERVICE_KEY is the service_role key (NOT the anon key).
#
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...
#
# ── Method A: Resend HTTP API (recommended — no domain needed) ──
# Free tier: 100 emails/day. Sends from onboarding@resend.dev.
# 1. Sign up at resend.com with your email
# 2. Create an API key at resend.com/api-keys
# 3. Set RESEND_API_KEY below
# 4. For production: verify your domain at resend.com/domains,
#    then change the "from" address in server.py to use your domain
#
RESEND_API_KEY=re_xxxxx
#
# ── Method B: SMTP (fallback — requires verified domain on Resend) ──
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=YOUR_RESEND_API_KEY
# SMTP_FROM=ArgueLab <briefing@yourdomain.com>
#
# ── Method C: Gmail SMTP (for personal testing) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.gmail@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=ArgueLab <your.gmail@gmail.com>
#
# ── Server settings ──
HOST=0.0.0.0
PORT=8080
BASE_URL=https://arguelab-production.up.railway.app
